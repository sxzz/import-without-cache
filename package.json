{
  "name": "import-without-cache",
  "type": "module",
  "version": "0.2.5",
  "packageManager": "pnpm@10.33.0",
  "description": "Import ES modules without cache.",
  "author": "Kevin Deng <sxzz@sxzz.moe>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/sxzz",
  "homepage": "https://github.com/sxzz/import-without-cache#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sxzz/import-without-cache.git"
  },
  "bugs": {
    "url": "https://github.com/sxzz/import-without-cache/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "node --test tests/index.test.js",
    "test:bun": "bun test tests/bun.test.ts",
    "typecheck": "tsgo --noEmit",
    "format": "prettier --cache --write .",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "^7.8.4",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260416.1",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2"
  },
  "prettier": "@sxzz/prettier-config"
}
